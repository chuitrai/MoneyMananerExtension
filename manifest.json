{
   "manifest_version": 3,
   "name": "Chui's money manager",
   "version": "1.0",
   "description": "A simple project to manage my money",
   "icons": {
      "48": "icons.png"
   },
   "action": {
      "default_popup": "popup.html",
      "default_icons": {
         "16": "icons.png",
         "48": "icons.png",
         "128": "icons.png"
      }
   },
   "permissions": [
      "storage"
   ]
}